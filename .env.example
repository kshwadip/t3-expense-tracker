# Auth
AUTH_SECRET=your-secret, You can generate a new secret on the command line with: npx auth secret
AUTH_DISCORD_ID=your-discord-client-id
AUTH_DISCORD_SECRET=your-discord-client-secret

# Database (Supabase)
DATABASE_URL=postgresql://...          # pgbouncer pooler :6543
DIRECT_URL=postgresql://...            # direct connection :5432

# Supabase Storage
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=...
SUPABASE_SERVICE_ROLE_KEY=...

# Groq (only needed by the worker, not Vercel)
GROQ_API_KEY=gsk_...